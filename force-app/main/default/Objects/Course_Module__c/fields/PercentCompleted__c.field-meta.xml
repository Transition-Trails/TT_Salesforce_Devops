<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>PercentCompleted__c</fullName>
    <businessStatus>Active</businessStatus>
    <complianceGroup>NA</complianceGroup>
    <description>Indicates level of completion based on related course activities</description>
    <formula>IF(Total_Activities__c = 0, 0,(Total_Closed_Activities__c / Total_Activities__c ))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Indicates level of completion based on related course activities</inlineHelpText>
    <label>% Completed</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <securityClassification>Public</securityClassification>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
