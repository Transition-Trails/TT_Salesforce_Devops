    <decisions>
        <description>Determine what to do with service contract</description>
        <name>Examine</name>
        <label>Examine</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Process_Service_Contracts</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Need_to_Activate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Process_Service_Contracts.StartDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Process_Service_Contracts.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Inactive</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddToUpdate</targetReference>
            </connector>
            <label>Need to Activate</label>
        </rules>
        <rules>
            <name>Expires_in_60_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Process_Service_Contracts.EndDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>ExpireDayDate60</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Process_Service_Contracts.Expiration_Notification_Date_60__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send60DayExpirationNotice</targetReference>
            </connector>
            <label>Expires in 60 Days</label>
        </rules>
        <rules>
            <name>Expires_in_90_days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Process_Service_Contracts.EndDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Expire90DayDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Process_Service_Contracts.Expiration_Notification_Date_90__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send90DayNotice</targetReference>
            </connector>
            <label>Expires in 90 days</label>
        </rules>
        <rules>
            <name>Expires_30_in_30_Days</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Process_Service_Contracts.EndDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>ExpiresDayDate30</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Process_Service_Contracts.Expiration_Notification_Date_30__c</leftValueReference>
