                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_30_Day_Expiration_Notice</targetReference>
            </connector>
            <label>Expires 30 in 30 Days</label>
        </rules>
        <rules>
            <name>Need_to_Deactivate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Process_Service_Contracts.EndDate</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Process_Service_Contracts.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Active</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AddToUpdateExpire</targetReference>
            </connector>
            <label>Need to Deactivate</label>
        </rules>
